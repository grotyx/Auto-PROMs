# OpenRouter (default provider): one key, any multimodal model
# https://openrouter.ai/keys
OPENROUTER_API_KEY=

# Auto Spine Survey - API Keys
# Copy this file to .env and fill in your API keys
# NEVER commit .env to git

# Anthropic Claude API Key (required if provider=claude)
CLAUDE_API_KEY=

# OpenAI API Key (required if provider=openai)
OPENAI_API_KEY=

# Google Gemini API Key (required if provider=gemini)
GEMINI_API_KEY=
